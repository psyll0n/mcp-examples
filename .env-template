########################################
# mcp-examples environment template
########################################

# NOTE:
# - Current examples run without requiring environment variables.
# - These values are starter defaults you can use if you decide
#   to read configuration from os.environ in the scripts.

# General
APP_ENV=development
LOG_LEVEL=info

# FastAPI calculator example defaults
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# FastMCP HTTP example defaults
FASTMCP_HTTP_HOST=localhost
FASTMCP_HTTP_PORT=8080

# Feed parser source defaults
FCC_NEWS_FEED_URL=https://www.freecodecamp.org/news/rss/
FCC_YOUTUBE_FEED_URL=https://www.youtube.com/feeds/videos.xml?channel_id=UC8butISFwT-Wl7EV0hUK0BQ
